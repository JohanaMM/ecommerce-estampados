# Servidor
PORT=3000
NODE_ENV=development

# Sesión (obligatorio en producción)
SESSION_SECRET=genera-un-string-aleatorio-y-seguro

# Base de datos
DB_USER=root
DB_PASSWORD=
DB_NAME=one_step
DB_HOST=127.0.0.1
DB_PORT=3306

# Opcional: usar una sola URL de conexión en producción
# USE_ENV_VARIABLE=DATABASE_URL

# API (URL pública del backend, para links en respuestas API)
API_URL=http://localhost:3000

# CORS (orígenes permitidos, separados por coma)
# CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=tu_access_token_de_mercadopago
MERCADOPAGO_CURRENCY=COP

# URL del frontend (para redirección después del pago)
FRONTEND_URL=http://localhost:3002

# Transferencia bancaria (pago por transferencia, 10% descuento)
# Usá TRANSFER_CVU o TRANSFER_CBU (el que corresponda a tu cuenta)
TRANSFER_CVU=0000003100123456789012
# TRANSFER_CBU=0000003100123456789012
TRANSFER_ALIAS=mi.cuenta.alias
TRANSFER_TITULAR=Nombre del Titular
TRANSFER_BANCO=Banco Ejemplo
# Link de WhatsApp para enviar comprobante (ej: https://wa.me/5491112345678)
WHATSAPP_LINK=https://wa.me/5491112345678

# Email (formulario de contacto)
EMAIL_USER=tu-email@gmail.com
EMAIL_PASS=tu-contraseña-de-aplicacion
EMAIL_CONTACT_TO=donde-recibir-contactos@ejemplo.com
